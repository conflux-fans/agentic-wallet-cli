# 每条链的变量按 ${CHAIN_KEY 大写}_ 前缀约定提供：
#   <KEY>_RPC_URL           (必需)
#   <KEY>_USDT_ADDRESS       (可选，覆盖默认 token 地址)
#   <KEY>_USDC_ADDRESS       (可选)
#   <KEY>_SCAN_API_URL       (可选)
#   <KEY>_SCAN_API_KEY       (可选)
# 新增一条链：在 src/chains/definitions.ts 的 CHAIN_DEFINITIONS 加一项，并在此按约定加变量。

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

PRIVATE_KEY=

CONFLUX_RPC_URL=
MONAD_RPC_URL=

CONFLUX_USDT_ADDRESS=
CONFLUX_USDC_ADDRESS=
MONAD_USDT_ADDRESS=
MONAD_USDC_ADDRESS=

CONFLUX_SCAN_API_URL=https://evmapi.confluxscan.io/api
CONFLUX_SCAN_API_KEY=
MONAD_SCAN_API_URL=
MONAD_SCAN_API_KEY=
